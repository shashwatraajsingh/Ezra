# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─────────────────────────────────────────
# Database (MySQL)
# ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=secret
DB_NAME=ezra_db

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRES_IN=7d
